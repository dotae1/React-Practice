import './App.css';
import { useState } from 'react';

// - value를 state로 만들기
// - Increase 버튼 함수 만들기 (+함수형 인자로)
// - Reset 버튼 함수 만들기
export default function App() {
  /**
   * useState는 배열을 반환 (value, setValue)
   * 첫번째 요소가 state값, 2번째 함수는 앞에 state를 변환하는 setter함수
   *  setter를 통해 value를 변경하면 appComponenet가 감지하여, 화면을 다시 그려주는 동작을 실행
   */
  const [value, setValue] = useState(0);

  return (
    <div>
      <h1>value : {value}</h1>
      <button onClick={() => {
        // log에 나오는 value1, 2는 처음에 버튼을 눌러도 0이나오는데 이는 바로 반영이 아니라 모든 함수가 끝나고 렌더링을 하기 떄문임.
        console.log('Increase Value1', value);
        setValue(value + 1);
        console.log('Increase Value2', value);
        // value = value + 1; //value는 처음 Jsx가 렌더링 한 상태를 유지하여, 값이 변해도 반영이 안됨. 따라서 갑의 변화를 감지하여 특수 변수 정의 필요
      }}
      >
        Increase value
        </button>
      <button onClick={()=> {
        setValue(0);
      }}>Reset Value</button>
    </div>
  );
}
