import './App.css';
import React, { Component } from 'react';

// Class가 Component가 되기 위하여, React에 있는 Component클래스를 상속받아야 한다.
// Class 컴포넌트는 이를 분리하지 않고, state 이름으로 하나의 오브젝트로 묶어서 관리한다.
export default class App extends Component {
// 멤버 변수로 state 정의
  state = {
    value : 0
  };
  // 함수형 State는 아래와 같음.
  // const [value, setValue1] = useState(0);
  // const [value, setValue1] = useState(0);

  //constrctor : class가 만들어질 떄 초기화된다.
  constructor(props) {
    super(props);
    this.state = {
      value : 1
    };
  }
  resetValue() {
    this.setState({ value: 0 });
  }

  render() {
    return (
      <div>
        <h1>value: {this.state.value}</h1>
        <button
          onClick={() => {
            this.setState((state) => ({
              value: state.value + 1
            }));
          }}
        >
          Increase value
        </button>
        <button
        // .bind this.ResetValue를 호출하게 되면, 안에 있는 this가 버튼 요소를 가르키게 된다. 따라서 에러가 발생
        // 이를 피하기 위해 AppClass의 this를 호출하여 에러를 피하게 된다. 
          onClick={this.resetValue.bind(this)}
        >
          Reset value
        </button>
      </div>
    );
  }
}
